{
  "name": "codi",
  "version": "0.1.0",
  "description": "노란 레서팬더 데스크톱 펫",
  "author": "유우리",
  "type": "commonjs",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "wait-on tcp:5173 && npm run electron:compile && electron .",
    "start": "concurrently -k \"npm run dev\" \"npm run electron:dev\"",
    "build:renderer": "tsc && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:renderer && npm run build:electron && electron-builder",
    "build:mac": "npm run build:renderer && npm run build:electron && electron-builder --mac",
    "verify:claude-jsonl": "node scripts/verify-claude-jsonl.cjs",
    "release:mac": "bash scripts/release-mac.sh",
    "version:patch": "npm version patch -m \"chore(release): %s\"",
    "version:minor": "npm version minor -m \"chore(release): %s\"",
    "version:major": "npm version major -m \"chore(release): %s\""
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "get-windows": "^9.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "systeminformation": "^5.31.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "wait-on": "^9.0.10"
  }
}
